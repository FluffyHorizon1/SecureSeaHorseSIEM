# Build directories
build/
out/
bin/
.vs/
.vscode/

# CMake artifacts
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# Compiled Binaries
*.exe
*.dll
*.lib
*.so
*.a
*.o
*.obj

# Logs and Data
*.log
*.csv

# Security - NEVER UPLOAD KEYS
*.crt
*.key
*.csr
*.pem
*.srl

# Vcpkg local installs
vcpkg_installed/

# Phase 2: Database credentials (if stored locally)
*.pgpass

# Phase 5: Threat intel feeds — KEEP sample feeds, ignore downloaded/custom feeds
# Uncomment the line below if you download large third-party feed files locally:
# config/feeds/custom_*.csv

# Phase 6: FIM baseline snapshots (generated at runtime, not version-controlled)
fim_baseline_*.json

# Phase 7: REST API token backups
rest_token_*.txt

# Phase 8: Incident response scripts (user-supplied)
scripts/*.sh
scripts/*.bat
scripts/*.ps1
# ...but keep shipped scripts
!scripts/generate_certs.sh

# Phase 9: Fleet snapshots (generated at runtime)
fleet_snapshot_*.json

# Phase 16: Sigma rules (user-supplied, keep shipped rules)
# config/sigma_rules/custom_*.yml

# Phase 17: Agent self-protection
agent_baseline.json
update_staging/

# Phase 18: Generated compliance reports
reports/*.pdf
reports/*.html

# Phase 20: Tenant and user databases (created at runtime)
users.db
tenants.db
*.jwt

# Phase 24: ML model persistence (generated at runtime)
ml_models/
